# Single-user auth. Generate the password hash with:
#   uv run python scripts/hash_password.py
OMILOG_USERNAME=you
OMILOG_PASSWORD_HASH=
# Use a long random string; anything signed with this is trusted as a logged-in user.
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
OMILOG_JWT_SECRET=
OMILOG_JWT_ALGORITHM=HS256
OMILOG_JWT_EXPIRE_MINUTES=10080

# Storage
OMILOG_STORAGE_DIR=storage
OMILOG_DB_PATH=omilog.db

# Server bind (Caddy / tailscale serve fronts this on the Pi)
OMILOG_HOST=127.0.0.1
OMILOG_PORT=8000

# Log level: DEBUG / INFO / WARNING
OMILOG_LOG_LEVEL=INFO

# Speech-to-text (whisper.cpp server). Leave OMILOG_STT_BASE_URL empty to
# disable the pipeline worker; pending_stt sessions will pile up until set.
OMILOG_STT_BASE_URL=http://gpu-host.tailnet:8080
OMILOG_STT_INFERENCE_PATH=/inference
OMILOG_STT_LANGUAGE=fr
OMILOG_STT_TIMEOUT_S=120
OMILOG_STT_MODEL_NAME=whisper-large-v3-turbo
# Optional decoding hints for whisper.cpp. initial_prompt is a short text
# that biases the model toward your vocabulary (proper nouns, technical
# terms, dominant language). temperature 0 = deterministic; 0.2 helps on
# noisy or low-volume audio. Leave both at defaults if you're not sure.
OMILOG_STT_INITIAL_PROMPT=
OMILOG_STT_TEMPERATURE=0

# How often the pipeline worker polls for pending sessions, in seconds.
OMILOG_PIPELINE_POLL_SECONDS=2
# Run the pipeline worker in its own thread (separate asyncio loop) so it
# can't starve the web server's loop. Default true. Only set false if you
# need to debug a race that's exclusive to the threaded mode.
OMILOG_PIPELINE_IN_THREAD=true

# WS rollover for all-day recording. Close the current capture every N seconds
# and start a new one while the WS stays open, so VAD/STT/LLM run throughout
# the day rather than waiting for the phone to disconnect. Set to 0 to disable.
OMILOG_WS_ROLLOVER_SECONDS=1800
OMILOG_WS_RECEIVE_TIMEOUT_SECONDS=5

# LLM extraction (llama.cpp server, OpenAI-compatible). Leave blank to disable
# the LLM stage — sessions will sit in pending_llm.
OMILOG_LLM_BASE_URL=http://gpu-host.tailnet:8081/v1
OMILOG_LLM_MODEL=qwen3.6-35b-a3b
OMILOG_LLM_TEMPERATURE=0.1
OMILOG_LLM_MAX_TOKENS=4096
OMILOG_LLM_TIMEOUT_S=180
# Optional hint that flavors the LLM prompt with a known primary language.
# Free-text like "French" or "Spanish". Empty = language-neutral; the model
# adapts to whatever it sees in the transcript. Whisper handles actual
# detection from audio independently of this.
OMILOG_LLM_PRIMARY_LANGUAGE=
# If this file exists, its contents replace the default LLM system prompt.
# Edit via the /config/prompt UI, or directly in any text editor. Leave the
# default path even if you don't customize — the file just won't exist.
OMILOG_LLM_SYSTEM_PROMPT_FILE=prompts/system_prompt.txt

# Per-category extraction toggles. When false, the prompt schema omits the
# section (saves output tokens) and the runner ignores anything the LLM
# returns for it anyway. Only affects future conversations; historical
# extractions stay put.
OMILOG_EXTRACT_CALENDAR_EVENTS=true
OMILOG_EXTRACT_ACTION_ITEMS=true
OMILOG_EXTRACT_DECISIONS=true
OMILOG_EXTRACT_PEOPLE_MENTIONED=true
OMILOG_EXTRACT_TOPICS=true

# Used to resolve relative date expressions ("demain", "next week", "vendredi")
# in extracted calendar events.
OMILOG_LOCAL_TIMEZONE=Europe/Paris

# Speaker diarization (Phase 4). All-local via sherpa-onnx. Requires the
# diarization extra + downloaded models:
#   uv sync --extra diarization
#   .venv/bin/python scripts/download_diarization_models.py
# Failures degrade gracefully (no labels, pipeline keeps going).
OMILOG_DIARIZATION_ENABLED=false
OMILOG_DIARIZATION_MODELS_DIR=models
OMILOG_DIARIZATION_SEGMENTATION_MODEL=models/sherpa-onnx-pyannote-segmentation-3-0/model.onnx
OMILOG_DIARIZATION_EMBEDDING_MODEL=models/nemo_en_titanet_small.onnx
OMILOG_DIARIZATION_MIN_SPEECH_SECONDS=0.3
OMILOG_DIARIZATION_MIN_SILENCE_SECONDS=0.5
# Force a specific speaker count per conversation (-1 = auto-detect via
# cluster threshold below). If your conversations are usually 2-4 people,
# setting this to e.g. 3 collapses the over-segmentation where short
# utterances get assigned to their own cluster each.
OMILOG_DIARIZATION_NUM_CLUSTERS=-1
# Cosine similarity threshold for sherpa-onnx's FastClustering when
# num_clusters=-1. Default 0.5. Empirically this knob has limited effect
# in practice — use POST_MERGE_THRESHOLD below for reliable cluster folding.
OMILOG_DIARIZATION_CLUSTER_THRESHOLD=0.5
# Cosine-similarity threshold for our own second-pass merge that runs
# AFTER sherpa-onnx. 1.0 = disabled (default). 0.7-0.85 is the useful
# range for the "diarizer returned 9 clusters but it was really 2 people"
# case — embeddings of the over-split clusters get compared and folded
# back together when they exceed this. Scales naturally with the real
# speaker count (unlike forcing num_clusters).
OMILOG_DIARIZATION_POST_MERGE_THRESHOLD=1.0
# Cap ONNX Runtime intra-op threads. Default 2 leaves a couple of cores
# free for the web server on a 4-core Pi. Bump to 4-6 on a beefier box.
OMILOG_DIARIZATION_NUM_THREADS=2
# Cosine similarity threshold for matching a detected voice to a known
# Speaker row across conversations. 0.6 is a good default; lower if your
# speakers sound similar (same gender, similar pitch); higher if omilog
# keeps merging distinct people.
OMILOG_SPEAKER_MATCH_THRESHOLD=0.6

# Daily-summary quality cutoff. Conversations whose effective_quality
# (override-or-LLM-score) is below this don't feed into the day's narrative.
# 0.3 = exclude noise but keep normal daily chatter. Bump to 0.5 if your
# generated summaries feel padded with too much small talk.
OMILOG_DAILY_SUMMARY_THRESHOLD=0.3

# Audio retention. Set to a positive integer (e.g. 30) to auto-delete .opus
# files older than that many days; transcripts and extractions are always
# kept. 0 (default) disables rotation entirely — audio piles up forever.
# Pin individual conversations via the 📌 button on their detail page to
# exempt them from rotation no matter how old.
OMILOG_AUDIO_RETENTION_DAYS=0

# ICS calendar feed token. Generate a fresh one:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# then subscribe your calendar app to https://<host>/calendar.ics?token=<token>.
# Leave blank to disable the feed.
OMILOG_ICS_FEED_TOKEN=
OMILOG_ICS_PRODID=-//omilog//EN
OMILOG_ICS_CALNAME=omilog
# Events below this confidence don't show up on the feed (overridable per
# request with ?min_confidence=).
OMILOG_ICS_FEED_MIN_CONFIDENCE=0.5

# Web UI cookie. Flip to true once Caddy/tailscale serve fronts the app on
# HTTPS; otherwise the browser will refuse to send the cookie back.
OMILOG_COOKIE_SECURE=false

# VAD / segmentation. Long captures are split at silence gaps >= this many
# seconds; everything below the threshold stays in one conversation.
OMILOG_VAD_ENABLED=true
OMILOG_VAD_GAP_SECONDS=60
OMILOG_VAD_THRESHOLD_DB=-40
OMILOG_VAD_MIN_SILENCE_SECONDS=0.5
OMILOG_VAD_PAD_SECONDS=0.4
OMILOG_VAD_CHILD_BITRATE=32k
