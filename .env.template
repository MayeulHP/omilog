# Single-user auth. Generate the password hash with:
#   uv run python scripts/hash_password.py
OMILOG_USERNAME=mayeul
OMILOG_PASSWORD_HASH=
# Use a long random string; anything signed with this is trusted as a logged-in user.
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
OMILOG_JWT_SECRET=
OMILOG_JWT_ALGORITHM=HS256
OMILOG_JWT_EXPIRE_MINUTES=10080

# Storage
OMILOG_STORAGE_DIR=storage
OMILOG_DB_PATH=omilog.db

# Server bind (Caddy / tailscale serve fronts this on the Pi)
OMILOG_HOST=127.0.0.1
OMILOG_PORT=8000

# Log level: DEBUG / INFO / WARNING
OMILOG_LOG_LEVEL=INFO

# Speech-to-text (whisper.cpp server). Leave OMILOG_STT_BASE_URL empty to
# disable the pipeline worker; pending_stt sessions will pile up until set.
OMILOG_STT_BASE_URL=http://gpu-host.tailnet:8080
OMILOG_STT_INFERENCE_PATH=/inference
OMILOG_STT_LANGUAGE=fr
OMILOG_STT_TIMEOUT_S=120
OMILOG_STT_MODEL_NAME=whisper-large-v3-turbo

# How often the pipeline worker polls for pending sessions, in seconds.
OMILOG_PIPELINE_POLL_SECONDS=2

# WS rollover for all-day recording. Close the current capture every N seconds
# and start a new one while the WS stays open, so VAD/STT/LLM run throughout
# the day rather than waiting for the phone to disconnect. Set to 0 to disable.
OMILOG_WS_ROLLOVER_SECONDS=1800
OMILOG_WS_RECEIVE_TIMEOUT_SECONDS=5

# LLM extraction (llama.cpp server, OpenAI-compatible). Leave blank to disable
# the LLM stage — sessions will sit in pending_llm.
OMILOG_LLM_BASE_URL=http://gpu-host.tailnet:8081/v1
OMILOG_LLM_MODEL=qwen3.6-35b-a3b
OMILOG_LLM_TEMPERATURE=0.1
OMILOG_LLM_MAX_TOKENS=4096
OMILOG_LLM_TIMEOUT_S=180
# Optional hint that flavors the LLM prompt with a known primary language.
# Free-text like "French" or "Spanish". Empty = language-neutral; the model
# adapts to whatever it sees in the transcript. Whisper handles actual
# detection from audio independently of this.
OMILOG_LLM_PRIMARY_LANGUAGE=

# Used to resolve relative date expressions ("demain", "next week", "vendredi")
# in extracted calendar events.
OMILOG_LOCAL_TIMEZONE=Europe/Paris

# Speaker diarization (Phase 4). All-local via sherpa-onnx. Requires the
# diarization extra + downloaded models:
#   uv sync --extra diarization
#   .venv/bin/python scripts/download_diarization_models.py
# Failures degrade gracefully (no labels, pipeline keeps going).
OMILOG_DIARIZATION_ENABLED=false
OMILOG_DIARIZATION_MODELS_DIR=models
OMILOG_DIARIZATION_SEGMENTATION_MODEL=models/sherpa-onnx-pyannote-segmentation-3-0/model.onnx
OMILOG_DIARIZATION_EMBEDDING_MODEL=models/nemo_en_titanet_small.onnx
OMILOG_DIARIZATION_MIN_SPEECH_SECONDS=0.3
OMILOG_DIARIZATION_MIN_SILENCE_SECONDS=0.5

# ICS calendar feed token. Generate a fresh one:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# then subscribe your calendar app to https://<host>/calendar.ics?token=<token>.
# Leave blank to disable the feed.
OMILOG_ICS_FEED_TOKEN=
OMILOG_ICS_PRODID=-//omilog//EN
OMILOG_ICS_CALNAME=omilog
# Events below this confidence don't show up on the feed (overridable per
# request with ?min_confidence=).
OMILOG_ICS_FEED_MIN_CONFIDENCE=0.5

# Web UI cookie. Flip to true once Caddy/tailscale serve fronts the app on
# HTTPS; otherwise the browser will refuse to send the cookie back.
OMILOG_COOKIE_SECURE=false

# VAD / segmentation. Long captures are split at silence gaps >= this many
# seconds; everything below the threshold stays in one conversation.
OMILOG_VAD_ENABLED=true
OMILOG_VAD_GAP_SECONDS=60
OMILOG_VAD_THRESHOLD_DB=-40
OMILOG_VAD_MIN_SILENCE_SECONDS=0.5
OMILOG_VAD_PAD_SECONDS=0.4
OMILOG_VAD_CHILD_BITRATE=32k
